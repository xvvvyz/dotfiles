#!/usr/bin/env zsh

set -euo pipefail

source "${0:A:h}/utilities/env"
source "${0:A:h}/utilities/fancy-print"

if command -v brew &>/dev/null; then
  fancy_print "cleaning brew..."
  brew cleanup --prune=all
  brew autoremove
fi

if command -v apt-get &>/dev/null; then
  fancy_print "cleaning apt..."
  sudo apt-get autoremove -y
  sudo apt-get autoclean -y
fi

if command -v bun &>/dev/null; then
  fancy_print "cleaning bun..."
  bun -g pm cache rm
fi

if command -v uv &>/dev/null; then
  fancy_print "cleaning uv..."
  uv cache clean
fi

if command -v nvim &>/dev/null; then
  fancy_print "cleaning neovim..."
  nvim --headless '+Lazy! clean' +qa
fi


if command -v journalctl &>/dev/null; then
  fancy_print "cleaning journalctl caches..."
  sudo journalctl --vacuum-time=7d
fi

if is_wsl; then
  fancy_print "cleaning windows temp files..."
  cmd.exe /C "del /q /s %TEMP%\*" > /dev/null 2>&1 || true
  cmd.exe /C "del /q /s C:\Windows\Temp\*" > /dev/null 2>&1 || true

  fancy_print "emptying recycle bin..."
  powershell.exe -Command "Clear-RecycleBin -Force -ErrorAction SilentlyContinue" > /dev/null 2>&1 || true
fi

if command -v docker &>/dev/null; then
  fancy_print "cleaning docker..."
  docker container prune -f
  docker image prune -a -f
  docker volume prune -a -f
  docker network prune -f
  docker builder prune -a -f
fi

fancy_print "done!"
