#!/usr/bin/env zsh

source "$(dirname "$0")/utilities/config"
source "$(dirname "$0")/utilities/fancy-print"

mkdir -p "${list_dir}"

if command -v brew; then
  fancy_print "saving brew packages list..."
  brew leaves > "${list_file_brew_packages}" 2>/dev/null || true

  fancy_print "saving brew casks list..."
  brew list --cask > "${list_file_brew_casks}" 2>/dev/null || true
fi

if command -v bun >/dev/null 2>&1; then
  fancy_print "saving bun packages list..."
  bun_global_package_file="${BUN_INSTALL:-${HOME}/.bun}/install/global/package.json"

  if [[ -f "${bun_global_package_file}" ]]; then
    bun --eval 'const pkg = JSON.parse(await Bun.file(process.argv[1]).text()); for (const name of Object.keys(pkg.dependencies ?? {}).sort()) { console.log(name); }' "${bun_global_package_file}" > "${list_file_bun_packages}"
  else
    : > "${list_file_bun_packages}"
  fi
fi

if command -v uv; then
  fancy_print "saving uv tools list..."
  uv tool list | grep -v '^-' | awk '{print $1}' > "${list_file_uv_tools}"
fi

if command -v winget.exe; then
  fancy_print "saving winget packages list..."
  win_tmp=$(cmd.exe /C "echo %TEMP%" 2>/dev/null | tr -d '\r')
  winget.exe export -o "${win_tmp}\\winget-packages.json" --accept-source-agreements > /dev/null 2>&1 || true

  grep PackageIdentifier "$(wslpath "${win_tmp}")/winget-packages.json" \
    | tr -d '\r' \
    | sed 's/.*: "//;s/"//' \
    | grep -Ev '^(Microsoft\.(VCRedist|VCLibs|DotNet|DirectX|UI\.Xaml|GameInput|AppInstaller|NET\.Native)|Nvidia\.PhysX|XP[A-Z0-9]+)' \
    > "${list_file_winget_packages}"

  fancy_print "backing up powertoys keyboard manager settings..."
  pt_kbm_src="${win_appdata_local}/Microsoft/PowerToys/Keyboard Manager"
  pt_kbm_dst="${copy_dir}/AppData/Local/Microsoft/PowerToys/Keyboard Manager"

  if [[ -d "$pt_kbm_src" ]]; then
    mkdir -p "$pt_kbm_dst"
    cp "$pt_kbm_src"/{default,settings}.json "$pt_kbm_dst"/
  fi
fi
